{
  "name": "babeljs-loose-spec",
  "version": "1.0.0",
  "description": "Show some edge cases of Babel",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "clean": "rm -rf lib",
    "build": "npm run clean && babel src --out-dir lib",
    "test": "ava",
    "test:src": "ava src",
    "test:lib": "ava lib",
    "lint": "standard",
    "lint:fix": "standard --fix"
  },
  "author": "xiaody",
  "license": "MIT",
  "ava": {
    "verbose": true
  },
  "dependencies": {
    "@babel/cli": "^7.29",
    "@babel/core": "^7.29",
    "@babel/preset-env": "^7.29",
    "ava": "^8",
    "standard": "^17"
  }
}
